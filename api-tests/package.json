{
  "name": "api-tests",
  "version": "1.0.0",
  "description": "REST API tests for blockchain transaction and wallet endpoints — Jest + axios",
  "scripts": {
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.spec.ts"
    ],
    "testTimeout": 30000
  }
}
